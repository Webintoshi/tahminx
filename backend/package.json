{
  "name": "tahminx-backend",
  "version": "1.0.0",
  "private": true,
  "description": "TahminX Sports Analytics Backend",
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main.js",
    "start:api": "node dist/src/main.js",
    "start:worker": "node dist/src/worker.js",
    "start:scheduler": "node dist/src/scheduler.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,test,prisma}/**/*.ts\"",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:deploy": "npm run prisma:migrate:deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:seed:safe": "node scripts/prisma-seed-safe.mjs",
    "health:check": "node scripts/health-check.mjs",
    "data:export": "ts-node src/scripts/export-critical-data.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.1.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.52.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.43.0",
    "argon2": "^0.41.1",
    "axios": "^1.9.0",
    "bullmq": "^5.56.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "nestjs-pino": "^4.3.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.1.3",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
